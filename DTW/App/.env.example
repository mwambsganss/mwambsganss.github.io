# DTW App — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── S3 Storage (optional — falls back to local filesystem if not set) ──────────
S3_BUCKET=your-bucket-name         # e.g. lilly-dtw-sessions
S3_REGION=us-east-1                # AWS region where the bucket lives
S3_PREFIX=dtw                      # key prefix inside the bucket

# AWS credentials — leave blank to use ~/.aws/credentials or IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── LLM Gateway ────────────────────────────────────────────────────────────────
LLM_GATEWAY_URL=https://lilly-code-server.api.gateway.llm.lilly.com
LLM_MODEL=claude-sonnet-4-6

# ── App ────────────────────────────────────────────────────────────────────────
PORT=5001
FLASK_SECRET_KEY=change-me-to-a-random-string
