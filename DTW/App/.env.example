# Anthropic API Key — required for AI exercise summaries
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Flask port (default 5001)
PORT=5001

# Optional: Facilitator passcode default (users can set per-session)
# FACILITATOR_PASSCODE=dtw2026

# Azure AD — required for automatic user name lookup (MSAL.js auth)
# Register a Single-Page Application in Azure AD, then paste the IDs here.
# If omitted, the app falls back to manual name entry.
AZURE_CLIENT_ID=your-azure-app-client-id-here
AZURE_TENANT_ID=your-azure-tenant-id-here
